rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Anyone signed in can read their own profile.
      // Admins can read all profiles (needed for AdminHub user list).
      allow read: if isOwner(uid) || isAdmin();

      // Users can write (create) their own profile on sign-up.
      allow create: if isOwner(uid);

      // Users can update their own profile; admins can update any profile.
      // IMPORTANT: neither owners nor admins may change the isAdmin field
      // directly from the client — that must go through the setAdminRole
      // Cloud Function (which uses the admin SDK and bypasses these rules).
      allow update: if (isOwner(uid) || isAdmin()) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);

      // Only admins can delete user documents (normally done via deleteUser CF).
      allow delete: if isAdmin();
    }

    // ── Groups ───────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      // Any signed-in user can read group metadata so they can search by join code.
      // Sensitive content (messages, games) is protected by sub-collection rules.
      allow read: if isSignedIn();

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.memberIds ||
        isAdmin() ||
        // Self-join: non-member may only add themselves to memberIds and members
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'members']) &&
          request.auth.uid in request.resource.data.memberIds &&
          !(request.auth.uid in resource.data.memberIds)
        )
      );

      allow delete: if isSignedIn() &&
        (request.auth.uid in resource.data.memberIds || isAdmin());

      // Messages sub-collection
      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds || isAdmin());

        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        allow delete: if isAdmin();
      }

      // Games sub-collection
      match /games/{gameId} {
        allow read: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds ||
          request.auth.uid in resource.data.get('guestIds', [])
        );

        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        allow update: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds ||
          // Non-members joining via game invite: may only write guestIds and their own rsvp entry
          (
            request.auth.uid in request.resource.data.get('guestIds', []) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guestIds', 'rsvps'])
          )
        );

        allow delete: if isAdmin() ||
          (isSignedIn() && request.auth.uid == resource.data.hostId) ||
          (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds);

        // Game chat messages — accessible to group members and game guests
        match /messages/{messageId} {
          allow read: if isSignedIn() && (
            isAdmin() ||
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds ||
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)/games/$(gameId)).data.get('guestIds', [])
          );

          allow create, update: if isSignedIn() && (
            isAdmin() ||
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds ||
            request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)/games/$(gameId)).data.get('guestIds', [])
          );

          allow delete: if isAdmin();
        }
      }
    }

    // ── Admin-only collections ────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /subscriptionPackages/{pkgId} {
      // Anyone signed in can read packages (e.g. for a pricing page).
      allow read: if isSignedIn();
      // Only admins can create, update, or delete packages.
      allow write: if isAdmin();
    }

    // ── Game join codes ───────────────────────────────────────────────────────
    // Top-level lookup table for game codes. Signed-in users can read (for
    // uniqueness checks and invite resolution) and write (create/update/delete
    // when managing their own game codes).
    match /gameCodes/{code} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
