{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/stripe-webhook",
        "function": "stripeWebhook",
        "region": "us-central1"
      },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
